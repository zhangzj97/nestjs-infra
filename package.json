{
  "name": "nestjs-infra",
  "version": "0.0.12",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "build": "tsdown src/index.ts --format esm,cjs --dts --clean",
    "release": "node scripts/release.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@zzj/ts-utils": "https://github.com/zhangzj97/ts-utils/releases/download/v0.1.3/dist.tar.gz",
    "ioredis": "^5.11.1",
    "mysql2": "^3.22.5",
    "rxjs": "^7.8.2",
    "typeorm": "^1.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "tsdown": "^0.22.3",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.0.9",
      "onFail": "download"
    }
  }
}
